# Core
PRODBUDDY_REQUEST_ID=local-dev

# Agent
AGENT_ENABLED=false
AGENT_PROVIDER=ollama
AGENT_BASE_URL=http://localhost:11434
AGENT_MODEL=gemma4:e4b
AGENT_CHAT_PATH=/api/generate
AGENT_AUTH_ENABLED=false
AGENT_API_KEY=
AGENT_STREAM_ENABLED=false
AGENT_THINKING_ENABLED=false
AGENT_FUNCTION_CALLING_ENABLED=false
AGENT_FUNCTION_CALLING_WITH_THINKING=false

# Elasticsearch
ELASTICSEARCH_BASE_URL=http://localhost:9200
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_AUTH_ENABLED=false
ELASTICSEARCH_DEFAULT_INDEX=_all

# New Relic
NEWRELIC_ACCOUNT_ID=
NEWRELIC_USER_API_KEY=
NEWRELIC_GRAPHQL_URL=https://api.newrelic.com/graphql

# Splunk
SPLUNK_BASE_URL=https://localhost:8089
SPLUNK_AUTH_MODE=token
SPLUNK_TOKEN=
SPLUNK_USERNAME=
SPLUNK_PASSWORD=
SPLUNK_SESSION_KEY=
SPLUNK_AUTH_ENABLED=true
SPLUNK_DEFAULT_INDEX=main
SPLUNK_DEFAULT_SEARCH=search index=_internal | head 10

# Generic HTTP tool
HTTP_DEFAULT_TIMEOUT_SECONDS=20
HTTP_DEFAULT_AUTH_ENABLED=false
HTTP_BEARER_TOKEN=

# Kubectl tool
KUBECTL_BINARY=kubectl
KUBECTL_NAMESPACE=default
KUBECTL_EXECUTE=false

# Code context tool
CODE_CONTEXT_MAX_RESULTS=20
CODE_CONTEXT_DB_PATH=.prodbuddy/codegraph
PRODBUDDY_PROJECT_PATH=.
PRODBUDDY_CODE_HINT=

# Recipes
RECIPES_DIR=recipes
